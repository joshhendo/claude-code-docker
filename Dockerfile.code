FROM debian:bookworm-slim

RUN apt-get update
RUN apt-get install -y --no-install-recommends \
	ca-certificates \
	gosu \
	curl \
	git \
	python3 \
	python3-pip \
	nodejs \
	npm \
	unzip

# Install uv (Python package manager required by Serena)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/ \
    && mv /root/.local/bin/uvx /usr/local/bin/

RUN npm install -g typescript typescript-language-server
RUN npm install -g claudish

RUN useradd -m coder

COPY --chown=coder:coder ./docker/init.sh /home/coder/init.sh
RUN chmod +x /home/coder/init.sh

COPY --chown=coder:coder ./defaults/claude.defaults.json /home/coder/claude.defaults.json
COPY --chown=coder:coder ./defaults/settings.defaults.json /home/coder/settings.defaults.json

USER coder
WORKDIR /home/coder

RUN curl -fsSL https://claude.ai/install.sh | bash
RUN curl -fsSL https://bun.sh/install | bash

ENV PATH="/home/coder/.claude/bin:/home/coder/.local/bin:${PATH}"

# Install the Serena MCP server
RUN uv tool install serena-agent

# Pre-seed Serena's TypeScript language server directory so it works offline at runtime
RUN mkdir -p /home/coder/.serena/language_servers/static/TypeScriptLanguageServer/ts-lsp \
    && cd /home/coder/.serena/language_servers/static/TypeScriptLanguageServer/ts-lsp \
    && npm init -y \
    && npm install typescript typescript-language-server

RUN mkdir -p /home/coder/.serena/language_servers/static/BashLanguageServer \
    && cd /home/coder/.serena/language_servers/static/BashLanguageServer \
    && npm init -y \
    && npm install --prefix ./ bash-language-server@5.6.0

WORKDIR /project
USER root

ENTRYPOINT ["sh", "/home/coder/init.sh"]
